---
permalink: /feed.xml
eleventyExcludeFromCollections: true
metadata:
  title: Clay Garden Press
  subtitle: Field notes and deep dives.
  url: https://claygardenpress.com/
  feedUrl: https://claygardenpress.com/feed.xml
  author:
    name: Clay Garden Press
    email: hello@claygardenpress.com
---
<?xml version="1.0" encoding="utf-8"?>
<feed xmlns="http://www.w3.org/2005/Atom">
  <title>{{ metadata.title }}</title>
  <subtitle>{{ metadata.subtitle }}</subtitle>
  <link href="{{ metadata.feedUrl }}" rel="self"/>
  <link href="{{ metadata.url }}"/>
  <updated>{{ collections.posts | getNewestCollectionItemDate | dateToRfc3339 }}</updated>
  <id>{{ metadata.url }}</id>
  <author>
    <name>{{ metadata.author.name }}</name>
    <email>{{ metadata.author.email }}</email>
  </author>
  {% for post in collections.posts %}
  <entry>
    <title>{{ post.data.title }}</title>
    <link href="{{ metadata.url }}{{ post.url | replace(r/^\//, '') }}"/>
    <updated>{{ post.date | dateToRfc3339 }}</updated>
    <id>{{ metadata.url }}{{ post.url | replace(r/^\//, '') }}</id>
    <summary>{{ post.data.description }}</summary>
    <content type="html">{{ post.templateContent | htmlToAbsoluteUrls(metadata.url + post.url) }}</content>
  </entry>
  {% endfor %}
</feed>
